            else:
                trigger_entry_price = ind["price"]  # 沒找到 → 用現價
                result["trigger_direction"] = "CURRENT"
            # 計算進場/止盈/止損價位（用觸發價格當進場價）
            ets = _compute_entry_tp_sl(s, ind, trigger_entry_price, chosen_dir)
