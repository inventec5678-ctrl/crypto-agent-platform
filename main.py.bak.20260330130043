    # 只取 verified 策略
    verified = [s for s in library if s.get("status") == "verified"]
    if not verified:
        verified = library[:5]

    # 計算指標
    try:
        ind = await compute_btc_indicators()
    except Exception as e:
        logger.error(f"Failed to compute BTC indicators: {e}")
        raise HTTPException(status_code=500, detail="Failed to fetch market data")

    # 每個策略計算符合度
    daily = ind.get("_daily", [])
    h4 = ind.get("_h4", [])
