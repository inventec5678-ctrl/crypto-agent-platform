    elif change_24h >= 0:
        return "↗️ 輕微上漲"
    elif change_24h >= -2:
        return "↘️ 輕微下跌"
    elif change_24h >= -5:
        return "📉 下跌趨勢"
    else:
        return "💥 強勢下跌"


