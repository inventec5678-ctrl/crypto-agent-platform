async def _check_one_volume(sym: str) -> dict | None:
    """並行檢查單一幣種的成交量異常（永遠回傳結果，無異常時也回傳統計）"""
    try:
        klines = await binance_client.get_klines(sym.upper(), "1d", limit=20)
        if not klines or len(klines) < 7:
            return None
        volumes = [float(k.get("volume", 0)) for k in klines]
        yesterday_vol = volumes[-2]
        hist_vols = volumes[-7:-2]
        if not hist_vols:
            return None
        avg_hist = sum(hist_vols) / len(hist_vols)
        ratio = yesterday_vol / avg_hist if avg_hist > 0 else 0
        is_anomaly = ratio > 3
        return {
            "symbol": sym.replace("USDT", ""),
            "today_volume": round(yesterday_vol, 2),
            "avg_volume": round(avg_hist, 2),
            "ratio": round(ratio, 2),
            "is_anomaly": is_anomaly,
            "severity": "critical" if ratio > 5 else ("warning" if is_anomaly else "normal"),
            "emoji": "🚨" if ratio > 5 else ("⚠️" if is_anomaly else "✅"),
            "time": datetime.now().strftime("%H:%M:%S"),
        }
    except Exception as e:
        logger.warning(f"Volume anomaly check failed for {sym}: {e}")
    return None


