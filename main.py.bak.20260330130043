def _ema(cs: list, period: int) -> float:
    """Calculate EMA for a list of close prices."""
    k_val = 2 / (period + 1)
    ema = cs[0]
    for cx in cs[1:]:
        ema = cx * k_val + ema * (1 - k_val)
    return ema


