def _eval_at_candle(candle_idx: int, conds: dict, daily: list, h4: list, tf: str) -> tuple:
    """Evaluate strategy conditions at a specific historical candle. Returns (matched, total)."""
    klines = daily if tf == "1D" else h4
    closes = [float(k["close"]) for k in klines]
    cs = closes[:candle_idx + 1]
    
    if len(cs) < 21:
        return 0, 0
    
    price = cs[-1]
    rsi_val = _rsi(cs)
    
    # MA cross
    ma20 = sum(cs[-20:]) / 20
    ma50 = sum(cs[-50:]) / 50
    ma200 = sum(cs[-200:]) / 200 if len(cs) >= 200 else None
    ma20_prev = sum(closes[max(0, candle_idx-20):candle_idx]) / min(20, candle_idx)
    ma50_prev = sum(closes[max(0, candle_idx-50):candle_idx]) / min(50, candle_idx)
    golden = ma20 > ma50 and ma20_prev <= ma50_prev
    death = ma20 < ma50 and ma20_prev >= ma50_prev
    
    # EMA cross
    ema9 = _ema(cs, 9)
    ema21 = _ema(cs, 21)
    ema9_above = ema9 > ema21
    ema9_below = ema9 < ema21
    cs_prev = closes[:candle_idx]
    if len(cs_prev) >= 21:
        ema9_prev = _ema(cs_prev, 9)
        ema21_prev = _ema(cs_prev, 21)
        ema_cross_above = ema9 > ema21 and ema9_prev <= ema21_prev
        ema_cross_below = ema9 < ema21 and ema9_prev >= ema21_prev
    else:
        ema_cross_above = ema_cross_below = False
    
    # Momentum
    momentum_7d = (cs[-1] - cs[-8]) / cs[-8] * 100 if len(cs) >= 8 else 0
    
    matched = 0
    total = 0
    for cond_name, cond_val in conds.items():
        if not cond_val:
            continue
        total += 1
        ok = False
        if cond_name == "golden_cross":
            ok = golden
        elif cond_name == "death_cross":
            ok = death
        elif cond_name == "SMA20_cross_above_SMA50":
