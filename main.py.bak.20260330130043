            result["tp_note"] = ets["tp_note"]
            # 新增：觸發方向
            result["trigger_direction"] = chosen_dir
            strategies_result.append(result)

    # 按 match_pct 降序
    strategies_result.sort(key=lambda x: x["match_pct"], reverse=True)

    return {
        "btc_price": ind["price"],
        "indicators": {
            "price": round(ind["price"], 2),
            "rsi": round(ind["rsi"], 2),
            "rsi_4h": round(ind["rsi_4h"], 2),
