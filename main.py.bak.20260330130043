def find_trigger_candle(strategy: dict, daily: list, h4: list, preferred_direction: str = None) -> dict | None:
    """往回找策略條件第一次 ALL 滿足的那根 K線（最多回看 60 根）。"""
    entry = strategy.get("entry", {})
    tf = strategy.get("timeframe", "1D")
    klines = daily if tf == "1D" else h4
    
    short_conds = entry.get("short", {})
    long_conds = entry.get("long", {})
    
    for i in range(len(klines) - 1, max(len(klines) - 60, 0), -1):
        if preferred_direction != "SHORT" and long_conds:
            m, t = _eval_at_candle(i, long_conds, daily, h4, tf)
            if m == t and t > 0:
                return {"candle": klines[i], "direction": "LONG", "trigger_index": i}
        
        if preferred_direction != "LONG" and short_conds:
            m, t = _eval_at_candle(i, short_conds, daily, h4, tf)
            if m == t and t > 0:
                return {"candle": klines[i], "direction": "SHORT", "trigger_index": i}
    
    return None



def _compute_entry_tp_sl(strategy: dict, ind: dict, entry_price: float, direction: str = "LONG") -> dict:
    """計算進場價、止盈價、止損價"""
    result = {
        "entry_price": round(entry_price, 2),
        "stop_loss": None,
        "take_profit": None,
        "sl_pct": None,
        "tp_pct": None,
        "tp_sl_ratio": None,
        "risk_reward": None,
        "tp_note": None,
    }

    result = {
        "entry_price": round(entry_price, 2),
        "stop_loss": None,
        "take_profit": None,
        "sl_pct": None,
        "tp_pct": None,
        "tp_sl_ratio": None,
        "risk_reward": None,
        "tp_note": None,
    }

    sl = strategy.get("stop_loss", "")
    tp = strategy.get("take_profit", "")
    timeframe = strategy.get("timeframe", "1D")

    # 止損計算
    if "ATR" in sl:
        # e.g., "2.0 ATR" or "1.5 ATR"
        m = re.search(r"([\d.]+)\s*ATR", sl)
        if m:
            mult = float(m.group(1))
            atr = ind.get("atr_14_4h", 700) if timeframe == "4H" else ind.get("atr_14", 2600)
            if direction == "LONG":
                result["stop_loss"] = round(entry_price - atr * mult, 2)
            else:
                result["stop_loss"] = round(entry_price + atr * mult, 2)
            result["sl_pct"] = round(atr * mult / entry_price * 100, 2)
    elif "%" in sl:
        m = re.search(r"([\d.]+)%", sl)
        if m:
            pct = float(m.group(1)) / 100
            if direction == "LONG":
                result["stop_loss"] = round(entry_price * (1 - pct), 2)
            else:
                result["stop_loss"] = round(entry_price * (1 + pct), 2)
            result["sl_pct"] = round(pct * 100, 2)

    # 止盈計算
    if "ATR trailing" in tp or "trailing" in tp.lower():
        result["take_profit"] = "ATR trailing (EMA cross exit)"
        result["tp_note"] = "移動止盈，跟蹤趨勢直到 EMA 反轉"
    elif "ATR" in tp:
        m = re.search(r"([\d.]+)\s*ATR", tp)
        if m:
            mult = float(m.group(1))
            atr = ind.get("atr_14_4h", 700) if timeframe == "4H" else ind.get("atr_14", 2600)
            if direction == "LONG":
                result["take_profit"] = round(entry_price + atr * mult, 2)
            else:
                result["take_profit"] = round(entry_price - atr * mult, 2)
            result["tp_pct"] = round(atr * mult / entry_price * 100, 2)
    elif "%" in tp:
        m = re.search(r"([\d.]+)%", tp)
        if m:
            pct = float(m.group(1)) / 100
            if direction == "LONG":
                result["take_profit"] = round(entry_price * (1 + pct), 2)
            else:
                result["take_profit"] = round(entry_price * (1 - pct), 2)
            result["tp_pct"] = round(pct * 100, 2)

    # Risk/Reward
    if result["stop_loss"] and result["take_profit"]:
        risk = abs(entry_price - result["stop_loss"])
        reward = abs(result["take_profit"] - entry_price)
        if risk > 0:
            result["risk_reward"] = round(reward / risk, 2)
            result["tp_sl_ratio"] = f"RR 1:{result['risk_reward']}"

    return result

async def compute_btc_indicators() -> dict:
    """計算 BTC 主要指標"""
    daily = await binance_client.get_klines("BTCUSDT", "1d", limit=250)
    h4 = await binance_client.get_klines("BTCUSDT", "4h", limit=200)

    closes_d = [float(k["close"]) for k in daily]
    closes_4h = [float(k["close"]) for k in h4]

    # MA
    ma20_d = sum(closes_d[-20:]) / 20
    ma50_d = sum(closes_d[-50:]) / 50
    ma200_d = sum(closes_d[-200:]) / 200

    # Golden/Death cross
    golden_cross = ma20_d > ma50_d
    death_cross = ma20_d < ma50_d

    # Price vs MA200
    price_above_ma200 = closes_d[-1] > ma200_d
    price_below_ma200 = closes_d[-1] < ma200_d

    # RSI (14)
    deltas = [closes_d[i] - closes_d[i-1] for i in range(1, len(closes_d))]
    gains = [d for d in deltas[-14:] if d > 0]
    losses = [-d for d in deltas[-14:] if d < 0]
    avg_gain = sum(gains)/14 if gains else 0
    avg_loss = sum(losses)/14 if losses else 0
    rs = avg_gain/avg_loss if avg_loss else 100
    rsi = 100 - (100/(1+rs))

    # Momentum (7-day % change)
    momentum_7d = (closes_d[-1] - closes_d[-8]) / closes_d[-8] * 100 if len(closes_d) >= 8 else 0

    # Regime (if MA200 > MA50 = bull, else bear)
    regime_bull = ma200_d > ma50_d
    regime_bear = ma200_d < ma50_d

    # 4H RSI (for 4H strategies)
    closes_4h_d = [float(k["close"]) for k in h4]
    deltas_4h = [closes_4h_d[i] - closes_4h_d[i-1] for i in range(1, len(closes_4h_d))]
    gains_4h = [d for d in deltas_4h[-14:] if d > 0]
    losses_4h = [-d for d in deltas_4h[-14:] if d < 0]
    avg_gain_4h = sum(gains_4h)/14 if gains_4h else 0
    avg_loss_4h = sum(losses_4h)/14 if losses_4h else 0
    rs_4h = avg_gain_4h/avg_loss_4h if avg_loss_4h else 100
    rsi_4h = 100 - (100/(1+rs_4h))

    # EMA 4H (EMA9 vs EMA21 for 4H strategy)
    def calc_ema(closes, period):
        k = 2 / (period + 1)
        ema = closes[0]
        for c in closes[1:]:
            ema = c * k + ema * (1 - k)
        return ema
    ema9_4h = calc_ema(closes_4h_d, 9)
    ema21_4h = calc_ema(closes_4h_d, 21)
    ema9_4h_above = ema9_4h > ema21_4h
    ema9_4h_below = ema9_4h < ema21_4h

    # EMA 1D (EMA8 vs EMA40 for 1D strategy)
    ema8_1d = calc_ema(closes_d, 8)
    ema40_1d = calc_ema(closes_d, 40)
    ema8_1d_above = ema8_1d > ema40_1d
    ema8_1d_below = ema8_1d < ema40_1d

    # ATR (14) — 用於 ATR-based SL/TP
    highs_d = [float(k.get("high", 0)) for k in daily]
    lows_d = [float(k.get("low", 0)) for k in daily]
    trs = []
    for i in range(1, len(daily)):
        tr = max(
            highs_d[i] - lows_d[i],
            abs(highs_d[i] - closes_d[i-1]),
            abs(lows_d[i] - closes_d[i-1])
        )
        trs.append(tr)
    atr_14 = sum(trs[-14:]) / 14 if len(trs) >= 14 else 0

    # 4H ATR
    highs_4h = [float(k.get("high", 0)) for k in h4]
    lows_4h = [float(k.get("low", 0)) for k in h4]
    closes_4h_list = [float(k["close"]) for k in h4]
    trs_4h = []
    for i in range(1, len(h4)):
        tr = max(
            highs_4h[i] - lows_4h[i],
            abs(highs_4h[i] - closes_4h_list[i-1]),
            abs(lows_4h[i] - closes_4h_list[i-1])
        )
        trs_4h.append(tr)
    atr_14_4h = sum(trs_4h[-14:]) / 14 if len(trs_4h) >= 14 else 0

    return {
        "price": closes_d[-1],
        "ma20": ma20_d, "ma50": ma50_d, "ma200": ma200_d,
        "golden_cross": golden_cross, "death_cross": death_cross,
        "price_above_ma200": price_above_ma200, "price_below_ma200": price_below_ma200,
        "rsi": rsi, "rsi_4h": rsi_4h,
        "momentum_7d": momentum_7d,
        "regime_bull": regime_bull, "regime_bear": regime_bear,
        "ema9_4h_above": ema9_4h_above, "ema9_4h_below": ema9_4h_below,
        "ema8_1d_above": ema8_1d_above, "ema8_1d_below": ema8_1d_below,
