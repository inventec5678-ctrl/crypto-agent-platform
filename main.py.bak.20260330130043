        elif cond_name == "SMA20_cross_below_SMA50":
            ok = death
        elif cond_name == "EMA9_cross_above_EMA21":
            ok = ema_cross_above
        elif cond_name == "EMA9_cross_below_EMA21":
            ok = ema_cross_below
        elif cond_name == "rsi_above_55":
            ok = rsi_val > 55
        elif cond_name == "rsi_below_45":
            ok = rsi_val < 45
        elif cond_name == "rsi_below_48":
            ok = rsi_val < 48
        elif cond_name == "rsi_below_50":
            ok = rsi_val < 50
        elif cond_name == "RSI_55_to_70":
            ok = 55 < rsi_val < 70
        elif cond_name == "momentum_7d_above_0.5pct":
            ok = momentum_7d > 0.5
        elif cond_name == "momentum_7d_below_minus0.5pct":
            ok = momentum_7d < -0.5
        elif cond_name == "momentum_7d_negative":
            ok = momentum_7d < 0
        elif cond_name == "price_above_ma200":
            ok = ma200 is not None and price > ma200
        elif cond_name == "price_below_ma200":
            ok = ma200 is not None and price < ma200
        elif cond_name == "close_below_MA200":
            ok = ma200 is not None and price < ma200
        if ok:
            matched += 1
    
    return matched, total

