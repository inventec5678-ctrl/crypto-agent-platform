            conds_str = ", ".join([f"{c} ✓" for c in result["matched_conditions"]])
            result["reason"] = f"{matched}/{total} 條件符合：{conds_str}" if conds_str else f"{matched}/{total} 條件符合"
            # 找觸發燭臺（往回找策略條件第一次 ALL 滿足時的價格）
            chosen_dir = result["direction"]  # LONG 或 SHORT（來自 _match_strategy）
            trigger = find_trigger_candle(s, daily, h4, preferred_direction=chosen_dir)
            if trigger:
                trigger_entry_price = float(trigger["candle"]["close"])
