def compute_signal(change_24h: float, confidence: float) -> tuple[str, str]:
    """根據價格變化和信心指數計算訊號"""
    if change_24h >= 3 and confidence >= 70:
        return "BUY", "signal-strong"
    elif change_24h >= 1.5 and confidence >= 55:
        return "BUY", "signal-medium"
    elif change_24h <= -3 and confidence >= 70:
        return "SELL", "signal-strong"
    elif change_24h <= -1.5 and confidence >= 55:
        return "SELL", "signal-medium"
    else:
        return "HOLD", "signal-weak"


def get_trend_label(change_24h: float) -> str:
    """根據 24h 變化回傳趨勢文字和 emoji"""
    if change_24h >= 5:
        return "🚀 強勢上漲"
    elif change_24h >= 2:
