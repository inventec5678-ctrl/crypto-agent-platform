def _classify_tier(wr: float, pf: float, dd: float, sharpe: float) -> str:
    """
    根據分層門檻計算策略 tier 等級
    
    - STANDARD:      WR≥50%, PF≥2.0, DD≤30%, Sharpe≥1.5（全部滿足）
    - RELAXED_PF_3:  WR≥40%, PF≥3.0（不通過 STANDARD 但 PF 突出）
    - RELAXED_SHARPE_3: WR≥40%, Sharpe≥3.0（不通過 STANDARD 但 Sharpe 突出）
    - DISCARD:       其他
    """
    # Layer 1 - 標準組合（全部滿足）
    if wr >= 50 and pf >= 2.0 and dd <= 30 and sharpe >= 1.5:
        return "STANDARD"
    
    # Layer 3 絕對底線（不通過則直接 DISCARD）
    if wr < 35 or pf < 1.0 or dd > 50 or sharpe < 0.5:
        return "DISCARD"
    
    # Layer 2 放寬組合（任一條件滿足即可）
    if wr >= 40 and pf >= 3.0:
        return "RELAXED_PF_3"
    
    if wr >= 40 and sharpe >= 3.0:
        return "RELAXED_SHARPE_3"
    
    return "DISCARD"


def _load_all_strategies_data() -> list[dict]:
    """載入所有實驗 + factor_library 策略，計算 tier，回傳完整列表"""
    base_dir = os.path.join(os.path.dirname(__file__), "autoresearch")
    experiments_dir = os.path.join(base_dir, "experiments")
    factor_library_path = os.path.join(base_dir, "factor_library.json")
    
    # ── 1. 讀取所有實驗檔，去重（取最高 PF）──────────────────────────────────
    strategy_best: dict[str, dict] = {}  # strategy_name -> best experiment data
    
    if os.path.isdir(experiments_dir):
        for fname in os.listdir(experiments_dir):
            if not fname.startswith("exp_") or not fname.endswith(".json"):
                continue
            fpath = os.path.join(experiments_dir, fname)
            try:
                with open(fpath, "r", encoding="utf-8") as f:
                    data = json.load(f)
            except (json.JSONDecodeError, OSError):
                continue
            
            m = data.get("metrics", {})
            pf = m.get("profit_factor", 0) or 0
            # win_rate in experiment files is already a ratio (0.33); convert to %
            wr_raw = m.get("win_rate", 0) or 0
            wr = wr_raw * 100 if wr_raw <= 1.0 else wr_raw
            
            name = data.get("strategy_name", "")
            if not name:
                continue
            
            # 只保留更高的 PF
            existing = strategy_best.get(name)
            if existing is None or pf > existing.get("profit_factor", 0):
                strategy_best[name] = {
                    "strategy_id": name,
                    "name": name,
                    "timeframe": m.get("timeframe", "1D"),
                    "source": "experiment",
                    "win_rate": round(wr, 2),
                    "profit_factor": round(pf, 2),
                    "max_drawdown": round(m.get("max_drawdown_pct", 0) or 0, 2),
                    "sharpe": round(m.get("sharpe_ratio", 0) or 0, 2),
                    "total_trades": int(m.get("total_trades", 0) or 0),
                    "status": data.get("status", "discard"),
                    "params": data.get("params", {}),
                }
    
    # ── 2. 合併 factor_library 中的已驗證策略 ───────────────────────────────
    if os.path.isfile(factor_library_path):
        try:
            with open(factor_library_path, "r", encoding="utf-8") as f:
                library = json.load(f)
            for item in library:
                m = item.get("metrics", {})
                # Library metrics are already in percentage form (71.43)
                wr = m.get("win_rate", 0) or 0
                pf = m.get("profit_factor", 0) or 0
                dd = m.get("max_drawdown", 0) or 0
                sharpe_val = m.get("sharpe", 0) or 0
                
                name = item.get("name", "") or item.get("strategy_id", "")
                if not name:
                    continue
                
                # Library strategies always have better PF than experiments; always include
                strategy_best[name] = {
                    "strategy_id": item.get("factor_id", name),
                    "name": name,
                    "timeframe": item.get("timeframe", "1D"),
                    "source": "library",
                    "win_rate": round(wr, 2),
                    "profit_factor": round(pf, 2),
                    "max_drawdown": round(dd, 2),
                    "sharpe": round(sharpe_val, 2),
                    "total_trades": int(m.get("total_trades", 0) or 0),
                    "status": item.get("status", "verified"),
                    "params": item.get("entry", {}),
                }
        except (json.JSONDecodeError, OSError) as e:
            logger.warning(f"Could not load factor_library.json: {e}")
    
    # ── 3. 計算 tier ─────────────────────────────────────────────────────────
    results = []
    for s in strategy_best.values():
        tier = _classify_tier(
            s["win_rate"], s["profit_factor"], s["max_drawdown"], s["sharpe"]
        )
        s["tier"] = tier
        results.append(s)
    
    # ── 4. 按 Sharpe 降序，只取 top 50 ────────────────────────────────────────
    results.sort(key=lambda x: x.get("sharpe", 0), reverse=True)
    return results[:50]


def _get_cached_all_strategies() -> list[dict]:
    """從快取取得所有策略（若未過期）"""
    entry = _all_strategies_cache.get("_data")
    if entry and (_time.time() - entry["ts"]) < _ALL_STRATEGIES_CACHE_TTL:
        return entry["data"]
    data = _load_all_strategies_data()
    _all_strategies_cache["_data"] = {"data": data, "ts": _time.time()}
    return data


