        # 回傳 K線供 find_trigger_candle 使用
        "_daily": daily,
        "_h4": h4,
    }


def _match_strategy(strategy: dict, ind: dict) -> dict:
    """計算單一策略的符合程度"""
    s_id = strategy.get("factor_id", "")
    name = strategy.get("name", "")
    entry = strategy.get("entry", {})
    timeframe = strategy.get("timeframe", "1D")

    # 根據 timeframe 決定用哪組 RSI
    use_4h = timeframe == "4H"

    # 決定進場方向：同時有 long/short 取 direction 參數或只看 long
    long_conds = entry.get("long", {})
    short_conds = entry.get("short", {})

    results = []

    # LONG 方向
    if long_conds:
        matched, total, matched_list = _check_conditions(long_conds, ind, use_4h)
        pct = round(matched / total * 100) if total > 0 else 0
        confidence = _get_confidence(pct)
        direction = "LONG"
        signal = "BUY" if pct >= 50 else "WAIT"
        results.append({
            "strategy_id": s_id, "name": name,
            "direction": direction, "timeframe": timeframe,
            "matched_conditions": matched_list,
            "total_conditions": total,
            "matched": matched,
            "match_pct": pct,
            "signal": signal, "confidence": confidence,
        })

    # SHORT 方向
    if short_conds:
        matched, total, matched_list = _check_conditions(short_conds, ind, use_4h)
        pct = round(matched / total * 100) if total > 0 else 0
        confidence = _get_confidence(pct)
        direction = "SHORT"
        signal = "SELL" if pct >= 50 else "WAIT"
        results.append({
            "strategy_id": s_id, "name": name,
            "direction": direction, "timeframe": timeframe,
            "matched_conditions": matched_list,
            "total_conditions": total,
            "matched": matched,
            "match_pct": pct,
            "signal": signal, "confidence": confidence,
        })

    # 回傳 match_pct 最高的結果
    return max(results, key=lambda x: x["match_pct"]) if results else None


def _check_conditions(conds: dict, ind: dict, use_4h: bool) -> tuple:
    """檢查策略條件，返回 (matched_count, total_count, [matched_condition_names])"""
    matched = 0
    total = 0
    matched_list = []

    for cond_name, cond_value in conds.items():
        if not cond_value:
            continue
        total += 1
        ok = False

        if cond_name == "golden_cross":
            ok = ind["golden_cross"]
        elif cond_name == "death_cross":
            ok = ind["death_cross"]
        elif cond_name == "rsi_above_55":
            ok = ind["rsi_above_55"]
        elif cond_name == "rsi_above_50":
            ok = ind["rsi_above_50"]
        elif cond_name == "rsi_below_45":
            ok = ind["rsi_below_45"]
        elif cond_name == "rsi_below_48":
            ok = ind["rsi_below_48"]
        elif cond_name == "rsi_below_50":
            ok = ind["rsi_below_50"]
        elif cond_name == "momentum_7d_above_0.5pct":
            ok = ind["momentum_7d_above_0.5"]
        elif cond_name == "momentum_7d_below_minus0.5pct":
            ok = ind["momentum_7d_below_minus0.5"]
        elif cond_name == "momentum_7d_negative":
            ok = ind["momentum_7d_negative"]
        elif cond_name == "price_above_ma200":
            ok = ind["price_above_ma200"]
        elif cond_name == "price_below_ma200":
            ok = ind["price_below_ma200"]
        elif cond_name == "regime_bull":
            ok = ind["regime_bull"]
        elif cond_name == "regime_bear":
            ok = ind["regime_bear"]
        elif cond_name == "RSI_55_to_70":
            ok = ind["rsi_4h_in_55_70"]
        elif cond_name == "RSI_above_50":
            # 1D strategy uses 1D RSI; 4H strategy uses 4H RSI
            ok = ind["rsi_above_50"] if not use_4h else ind["rsi_4h_above_50"]
        elif cond_name == "RSI_below_50":
            ok = ind["rsi_below_50"] if not use_4h else ind["rsi_4h_above_50"] is False  # simplified
        elif cond_name == "RSI_below_45":
            ok = ind["rsi_below_45"]
        elif cond_name == "EMA9_cross_above_EMA21":
            ok = ind["ema9_4h_above"]
        elif cond_name == "EMA9_cross_below_EMA21":
            ok = ind["ema9_4h_below"]
        elif cond_name == "EMA8_cross_above_EMA40":
            ok = ind["ema8_1d_above"]
        elif cond_name == "EMA8_cross_below_EMA40":
            ok = ind["ema8_1d_below"]
        elif cond_name == "EMA10_cross_above_EMA15":
            # Not in our simplified indicators, skip gracefully
            ok = ind.get("ema9_4h_above", False)
        elif cond_name == "EMA10_cross_below_EMA15":
            ok = ind.get("ema9_4h_below", False)
        elif cond_name == "SMA20_cross_below_SMA50":
            ok = ind["death_cross"]
        elif cond_name == "close_below_MA200":
            ok = ind["price_below_ma200"]
        elif cond_name == "MA200_slope_negative":
            # Approximate: regime_bear when ma200 < ma50
            ok = ind["regime_bear"]
        elif cond_name == "volume_above_ma20":
            # Volume check - not computed in simplified version
            ok = True  # neutral
        elif cond_name == "RSI_16_above_50":
            ok = ind["rsi_4h_above_50"]
        elif cond_name == "RSI_16_below_50":
            ok = ind["rsi_4h_above_50"] is False

        if ok:
            matched += 1
            matched_list.append(cond_name)

    return matched, total, matched_list


def _get_confidence(pct: int) -> str:
    if pct >= 90: return "STRONG"
    if pct >= 70: return "HIGH"
    if pct >= 50: return "MEDIUM"
    return "LOW"


@app.get("/api/strategies/live")
async def get_live_strategy_matches():
    """
    即時策略符合度計算
    - 從 factor_library.json 讀取已驗證的策略
    - 取得 BTC 即時指標
    - 計算每個策略的條件符合程度
