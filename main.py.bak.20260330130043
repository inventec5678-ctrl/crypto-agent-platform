# ─── 大額掛單追蹤 ─────────────────────────────────────────────────────────────

class LargeOrderTracker:
    """大額掛單追蹤器"""
    
    def __init__(self):
        self._order_book_cache: dict[str, dict] = {}
        self._large_orders: list[dict] = []
        self._tracking_tasks: dict[str, asyncio.Task] = {}
    
    async def track_symbol(self, symbol: str):
        """追蹤單一幣種的大額掛單"""
        ws_url = f"wss://stream.binance.com:9443/ws/{symbol.lower()}@depth"
        
        while True:
            try:
                async with websockets.connect(ws_url) as ws:
                    logger.info(f"Connected to depth stream: {symbol}")
                    async for raw in ws:
                        try:
                            # In websockets 16.0, raw is already the string data
                            data = raw if isinstance(raw, dict) else json.loads(raw)
                            await self._process_depth_update(symbol, data)
                        except Exception as e:
                            logger.error(f"Error processing depth update for {symbol}: {e}")
                            continue
            except Exception as e:
                logger.error(f"WebSocket error for {symbol}: {e}, reconnecting in 5s...")
                await asyncio.sleep(5)
    
    async def _process_depth_update(self, symbol: str, data: dict):
        """處理訂單簿更新"""
        # 處理 Depth 訂單簿數據
        bids = data.get("b", data.get("bids", []))  # 買單 [price, qty]
        asks = data.get("a", data.get("asks", []))  # 賣單 [price, qty]
        
        # 追蹤大額掛單 (> 10 BTC)
        large_orders = []
        
        for bid in bids[:5]:  # 前 5 筆買單
            qty = float(bid[1])
            if qty > 10:  # > 10 BTC
                severity = "critical" if qty > 50 else "warning"
                emoji = "🚨" if qty > 50 else "⚠️"
                large_orders.append({
                    "symbol": symbol.replace("USDT", ""),
                    "side": "BID",
                    "price": float(bid[0]),
                    "quantity": round(qty, 4),
                    "severity": severity,
                    "emoji": emoji,
                    "timestamp": datetime.now().isoformat()
                })
        
        for ask in asks[:5]:  # 前 5 筆賣單
            qty = float(ask[1])
            if qty > 10:  # > 10 BTC
                severity = "critical" if qty > 50 else "warning"
                emoji = "🚨" if qty > 50 else "⚠️"
                large_orders.append({
                    "symbol": symbol.replace("USDT", ""),
                    "side": "ASK",
                    "price": float(ask[0]),
                    "quantity": round(qty, 4),
                    "severity": severity,
                    "emoji": emoji,
                    "timestamp": datetime.now().isoformat()
                })
        
        if large_orders:
            self._large_orders.extend(large_orders)
            # 保持最近 100 筆記錄
            self._large_orders = self._large_orders[-100:]
    
    def get_large_orders(self, limit: int = 50) -> list:
        """取得大額掛單記錄"""
        return self._large_orders[-limit:]
    
    async def start_tracking(self, symbols: list[str]):
        """啟動追蹤任務"""
        for sym in symbols:
            if sym not in self._tracking_tasks:
                task = asyncio.create_task(self.track_symbol(sym))
                self._tracking_tasks[sym] = task
    
    def stop_tracking(self, symbol: str = None):
        """停止追蹤任務"""
        if symbol:
            if symbol in self._tracking_tasks:
                self._tracking_tasks[symbol].cancel()
                del self._tracking_tasks[symbol]
        else:
            for task in self._tracking_tasks.values():
                task.cancel()
            self._tracking_tasks.clear()


