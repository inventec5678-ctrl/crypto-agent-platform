# Strategies module
from strategies.strategy_ma_crossover import MACrossoverStrategy
from strategies.strategy_rsi import RSIReversalStrategy
from strategies.strategy_bb import BBBreakoutStrategy
from strategies.volume_strategy import VolumeBreakoutStrategy


def get_all_strategies(symbol: str = "BTCUSDT"):
    """
    取得所有策略實例
    
    Args:
        symbol: 交易對，如 BTCUSDT, ETHUSDT
    
    Returns:
        list: 策略實例列表
    """
    return [
        MACrossoverStrategy(symbol=symbol),
        RSIReversalStrategy(symbol=symbol),
        BBBreakoutStrategy(symbol=symbol),
        VolumeBreakoutStrategy(symbol=symbol),
    ]


__all__ = [
    "MACrossoverStrategy",
    "RSIReversalStrategy",
    "BBBreakoutStrategy",
    "VolumeBreakoutStrategy",
    "get_all_strategies",
]
